{%- comment -%} Usage: {% render 'product-grid-item', product: product %} {%- endcomment -%}

{%- assign in_stock = false -%}
{%- for variant in product.variants -%}
  {%- if variant.inventory_quantity > 0 or variant.inventory_management == blank -%}
    {%- assign in_stock = true -%}
  {%- endif -%}
{%- endfor -%}
{%- assign discount_pct = 0 -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
{%- endif -%}

<article class="product-card" itemscope itemtype="https://schema.org/Product">
  <a href="{{ product.url }}" class="product-card__link" aria-label="{{ product.title | escape }}">
    <div class="product-card__media">
      {%- if product.featured_image -%}
        {{ product.featured_image | image_url: width: 600
          | image_tag:
            class: 'product-card__img',
            loading: 'lazy',
            alt: product.featured_image.alt,
            itemprop: 'image',
            widths: '300, 400, 600',
            sizes: '(max-width:480px) calc(50vw - 24px), (max-width:900px) calc(50vw - 32px), calc(25vw - 32px)' }}

        {%- if product.images[1] -%}
          {{ product.images[1] | image_url: width: 600
            | image_tag: class: 'product-card__img product-card__img--hover', loading: 'lazy', alt: product.title }}
        {%- endif -%}
      {%- else -%}
        <div style="width:100%;height:100%;background:#f0ece6;display:flex;align-items:center;justify-content:center;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
          </svg>
        </div>
      {%- endif -%}

      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__badge product-card__badge--sale">-{{ discount_pct }}%</span>
      {%- elsif product.tags contains 'nuevo' or product.tags contains 'new' -%}
        <span class="product-card__badge product-card__badge--new">Nuevo</span>
      {%- endif -%}

      <div class="product-card__overlay"></div>

      {%- if in_stock -%}
        <button class="product-card__quick"
          data-product-id="{{ product.variants.first.id }}"
          aria-label="Agregar {{ product.title | escape }} al carrito">
          + Agregar al carrito
        </button>
      {%- endif -%}
    </div>
  </a>

  <div class="product-card__info">
    {%- if product.vendor != blank -%}
      <p class="product-card__vendor" itemprop="brand">{{ product.vendor }}</p>
    {%- endif -%}

    <h3 class="product-card__title" itemprop="name">
      <a href="{{ product.url }}" style="text-decoration:none;">{{ product.title }}</a>
    </h3>

    <div class="product-card__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__price--compare">{{ product.compare_at_price | money }}</span>
        <span class="product-card__price--current product-card__price--sale" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">
          {{ product.price | money }}
        </span>
      {%- else -%}
        <span class="product-card__price--current" itemprop="price" content="{{ product.price | divided_by: 100.0 }}">
          {%- if product.price_varies -%}Desde {% endif -%}
          {{ product.price | money }}
        </span>
      {%- endif -%}
      <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
      <link itemprop="availability" href="https://schema.org/{% if in_stock %}InStock{% else %}OutOfStock{% endif %}">
    </div>
  </div>
</article>
