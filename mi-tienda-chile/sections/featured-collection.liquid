{%- style -%}
  .featured-collection { padding: {{ section.settings.padding_v }}px 1rem; }
  .featured-collection__header { text-align: center; margin-bottom: 2rem; }
  .featured-collection__title { font-size: 2rem; font-weight: 700; margin: 0 0 .5rem; }
  .featured-collection__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.gap }}px;
    max-width: 1400px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .featured-collection__grid { grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr); }
  }
{%- endstyle -%}

{%- assign collection = collections[section.settings.collection] -%}

<section class="featured-collection">
  <div class="featured-collection__header">
    <h2 class="featured-collection__title">{{ section.settings.title | default: collection.title }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p>{{ section.settings.subtitle }}</p>
    {%- endif -%}
  </div>

  {%- if collection != blank -%}
    <div class="featured-collection__grid">
      {%- for product in collection.products limit: section.settings.products_to_show -%}
        {% render 'product-grid-item', product: product %}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p style="text-align:center;color:#999;">Selecciona una colección en el editor.</p>
  {%- endif -%}

  {%- if section.settings.show_view_all and collection != blank -%}
    <div style="text-align:center;margin-top:2rem;">
      <a href="{{ collection.url }}" style="display:inline-block;padding:.75rem 2rem;border:2px solid currentColor;text-decoration:none;font-weight:600;">
        {{ section.settings.view_all_label | default: 'Ver todo' }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Colección Destacada",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "text", "id": "title", "label": "Título", "default": "Productos Destacados" },
    { "type": "text", "id": "subtitle", "label": "Subtítulo" },
    { "type": "range", "id": "products_to_show", "label": "Productos a mostrar", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_desktop", "label": "Columnas (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_mobile", "label": "Columnas (móvil)", "min": 1, "max": 2, "step": 1, "default": 2 },
    { "type": "range", "id": "gap", "label": "Espacio entre items (px)", "min": 8, "max": 48, "step": 4, "default": 20 },
    { "type": "range", "id": "padding_v", "label": "Padding vertical (px)", "min": 20, "max": 120, "step": 10, "default": 60 },
    { "type": "checkbox", "id": "show_view_all", "label": "Mostrar 'Ver todo'", "default": true },
    { "type": "text", "id": "view_all_label", "label": "Texto 'Ver todo'", "default": "Ver toda la colección" }
  ],
  "presets": [{ "name": "Colección Destacada" }]
}
{% endschema %}
