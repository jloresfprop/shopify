{%- style -%}
  .contact-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 5rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }
  @media (max-width: 768px) {
    .contact-page { grid-template-columns: 1fr; gap: 3rem; padding: 3rem 1.5rem; }
  }

  /* Info lateral */
  .contact-info__eyebrow {
    font-size: .72rem; font-weight: 700; letter-spacing: .16em;
    text-transform: uppercase; color: #c9a84c;
    display: flex; align-items: center; gap: .5rem;
    margin-bottom: 1rem;
  }
  .contact-info__eyebrow::before { content: ''; width: 24px; height: 2px; background: #c9a84c; display: block; }
  .contact-info__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700; line-height: 1.15;
    color: #0d0d0d; margin-bottom: 1.25rem;
  }
  .contact-info__desc { font-size: 1rem; color: #555; line-height: 1.75; margin-bottom: 2.5rem; }

  .contact-info__items { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-info__item { display: flex; gap: 1rem; align-items: flex-start; }
  .contact-info__icon {
    width: 44px; height: 44px; flex-shrink: 0;
    background: #f7f3ed; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #c9a84c;
  }
  .contact-info__label {
    font-size: .72rem; font-weight: 700; letter-spacing: .08em;
    text-transform: uppercase; color: #999; margin-bottom: .2rem;
  }
  .contact-info__value { font-size: .95rem; color: #0d0d0d; font-weight: 500; }
  .contact-info__value a { color: #c9a84c; }

  /* Formulario */
  .contact-form {
    background: #f7f3ed;
    border-radius: 12px;
    padding: 2.5rem;
  }
  .contact-form__title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem; font-weight: 700;
    margin-bottom: 1.75rem; color: #0d0d0d;
  }
  .contact-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  @media (max-width: 480px) { .contact-form__row { grid-template-columns: 1fr; } }

  .contact-form__field { display: flex; flex-direction: column; gap: .4rem; margin-bottom: 1.25rem; }
  .contact-form__label {
    font-size: .78rem; font-weight: 700;
    letter-spacing: .06em; text-transform: uppercase; color: #555;
  }
  .contact-form__input,
  .contact-form__select,
  .contact-form__textarea {
    width: 100%;
    padding: .75rem 1rem;
    border: 1.5px solid #e0d9cf;
    border-radius: 6px;
    background: #fff;
    font-family: 'Inter', sans-serif;
    font-size: .95rem;
    color: #0d0d0d;
    transition: border-color .2s, box-shadow .2s;
    outline: none;
  }
  .contact-form__input:focus,
  .contact-form__select:focus,
  .contact-form__textarea:focus {
    border-color: #c9a84c;
    box-shadow: 0 0 0 3px rgba(201,168,76,.15);
  }
  .contact-form__textarea { resize: vertical; min-height: 130px; }
  .contact-form__submit {
    width: 100%;
    padding: .95rem;
    background: #0d0d0d;
    color: #fff;
    border: 2px solid #0d0d0d;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-size: .88rem; font-weight: 700;
    letter-spacing: .08em; text-transform: uppercase;
    cursor: pointer; transition: all .25s;
    margin-top: .5rem;
  }
  .contact-form__submit:hover { background: #c9a84c; border-color: #c9a84c; color: #0d0d0d; }

  .contact-form__success {
    display: none;
    background: #d4edda; border: 1px solid #c3e6cb;
    border-radius: 6px; padding: 1rem 1.25rem;
    color: #155724; font-size: .9rem; margin-bottom: 1rem;
  }
  .contact-form__success.is-visible { display: block; }
{%- endstyle -%}

<div class="contact-page">

  <div class="contact-info">
    <p class="contact-info__eyebrow">Contáctanos</p>
    <h1 class="contact-info__title">{{ section.settings.title }}</h1>
    <p class="contact-info__desc">{{ section.settings.description }}</p>

    <div class="contact-info__items">
      {%- if section.settings.email != blank -%}
        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="contact-info__label">Email</p>
            <p class="contact-info__value"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.phone != blank -%}
        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.74a16 16 0 0 0 6.29 6.29l1.62-1.62a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="contact-info__label">Teléfono / WhatsApp</p>
            <p class="contact-info__value"><a href="https://wa.me/{{ section.settings.phone | remove: '+' | remove: ' ' }}">{{ section.settings.phone }}</a></p>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.schedule != blank -%}
        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <p class="contact-info__label">Horario de atención</p>
            <p class="contact-info__value">{{ section.settings.schedule }}</p>
          </div>
        </div>
      {%- endif -%}

      {%- if section.settings.address != blank -%}
        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <p class="contact-info__label">Dirección</p>
            <p class="contact-info__value">{{ section.settings.address }}</p>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="contact-form">
    <h2 class="contact-form__title">Envíanos un mensaje</h2>

    {%- form 'contact', id: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <div class="contact-form__success is-visible">
          Mensaje enviado correctamente. Te responderemos a la brevedad.
        </div>
      {%- endif -%}

      <div class="contact-form__row">
        <div class="contact-form__field">
          <label class="contact-form__label" for="contact-name">Nombre</label>
          <input class="contact-form__input" type="text" id="contact-name"
            name="contact[name]" value="{{ form.name }}" placeholder="Tu nombre" required>
        </div>
        <div class="contact-form__field">
          <label class="contact-form__label" for="contact-email">Email</label>
          <input class="contact-form__input" type="email" id="contact-email"
            name="contact[email]" value="{{ form.email }}" placeholder="tu@email.com" required>
        </div>
      </div>

      <div class="contact-form__field">
        <label class="contact-form__label" for="contact-subject">Motivo</label>
        <select class="contact-form__select" id="contact-subject" name="contact[subject]">
          <option value="">Selecciona un motivo...</option>
          <option>Consulta sobre un producto</option>
          <option>Estado de mi pedido</option>
          <option>Devolución o cambio</option>
          <option>Despacho y envío</option>
          <option>Otro</option>
        </select>
      </div>

      <div class="contact-form__field">
        <label class="contact-form__label" for="contact-message">Mensaje</label>
        <textarea class="contact-form__textarea" id="contact-message"
          name="contact[body]" placeholder="Escribe tu mensaje aquí..." required>{{ form.body }}</textarea>
      </div>

      <button type="submit" class="contact-form__submit">
        Enviar mensaje
      </button>
    {%- endform -%}
  </div>

</div>

{% schema %}
{
  "name": "Página de Contacto",
  "settings": [
    { "type": "text", "id": "title", "label": "Título", "default": "¿En qué podemos ayudarte?" },
    { "type": "textarea", "id": "description", "label": "Descripción", "default": "Estamos aquí para responder todas tus preguntas. Escríbenos y te responderemos a la brevedad." },
    { "type": "text", "id": "email", "label": "Email de contacto" },
    { "type": "text", "id": "phone", "label": "Teléfono / WhatsApp (con código país, ej: +56912345678)" },
    { "type": "text", "id": "schedule", "label": "Horario de atención", "default": "Lun – Vie, 9:00 – 18:00 hrs" },
    { "type": "text", "id": "address", "label": "Dirección (opcional)" }
  ]
}
{% endschema %}
