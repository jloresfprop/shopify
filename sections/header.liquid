{%- style -%}
  .header {
    position: sticky; top: 0; z-index: 200;
    background: {{ section.settings.bg_color }};
    border-bottom: 1px solid rgba(0,0,0,.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .header__inner {
    max-width: 1400px; margin: 0 auto;
    padding: 0 2rem;
    height: 72px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }
  .header__logo { display: flex; align-items: center; text-decoration: none; }
  .header__logo-svg { height: 42px; width: auto; }
  .header__logo-img { height: 42px; width: auto; }
  .header__nav { display: flex; justify-content: center; }
  .header__nav ul { display: flex; gap: 2.25rem; list-style: none; }
  .header__nav a {
    text-decoration: none;
    font-size: .82rem; font-weight: 600;
    letter-spacing: .1em; text-transform: uppercase;
    color: {{ section.settings.text_color }};
    position: relative; padding-bottom: 3px;
  }
  .header__nav a::after {
    content: ''; position: absolute; bottom: 0; left: 0;
    width: 0; height: 2px; background: #c9a84c;
    transition: width .25s ease;
  }
  .header__nav a:hover::after,
  .header__nav a[aria-current]::after { width: 100%; }
  .header__actions { display: flex; justify-content: flex-end; align-items: center; gap: .5rem; }
  .header__icon-btn {
    background: none; border: none; cursor: pointer;
    padding: .5rem; border-radius: 4px;
    color: {{ section.settings.text_color }};
    display: flex; align-items: center;
    transition: background .2s;
  }
  .header__icon-btn:hover { background: rgba(0,0,0,.05); }
  .header__cart-wrap { position: relative; }
  .header__cart-count {
    position: absolute; top: -4px; right: -4px;
    width: 18px; height: 18px;
    background: #c9a84c; color: #0d0d0d;
    font-size: .65rem; font-weight: 800;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .header__hamburger { display: none; }
  .header__drawer {
    display: none; position: fixed; inset: 0; z-index: 300;
    background: rgba(0,0,0,.5); opacity: 0; pointer-events: none;
    transition: opacity .3s;
  }
  .header__drawer.is-open { opacity: 1; pointer-events: all; }
  .header__drawer-panel {
    position: absolute; top: 0; left: 0;
    width: min(320px, 85vw); height: 100%;
    background: #0d0d0d; color: #fff;
    padding: 2rem 1.5rem;
    transform: translateX(-100%);
    transition: transform .3s ease;
    overflow-y: auto;
  }
  .header__drawer.is-open .header__drawer-panel { transform: translateX(0); }
  .header__drawer-close {
    background: none; border: none; cursor: pointer; color: #fff;
    margin-bottom: 2rem; display: block;
  }
  .header__drawer ul { list-style: none; }
  .header__drawer li + li { border-top: 1px solid rgba(255,255,255,.1); }
  .header__drawer a { display: block; padding: 1rem 0; color: #fff; font-size: 1.1rem; font-weight: 500; }
  @media (max-width: 900px) {
    .header__inner { grid-template-columns: auto 1fr; }
    .header__nav { display: none; }
    .header__hamburger { display: flex; }
    .header__drawer { display: block; }
  }
{%- endstyle -%}

<header class="header" role="banner">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: height: 84 | image_tag: class: 'header__logo-img', loading: 'eager' }}
      {%- else -%}
        <svg class="header__logo-svg" viewBox="0 0 220 56" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Estante: base y soporte -->
          <rect x="1" y="42" width="42" height="3" rx="1.5" fill="#C9A84C"/>
          <rect x="1" y="22" width="42" height="2.5" rx="1.2" fill="#C9A84C" opacity=".6"/>
          <rect x="2" y="22" width="2.5" height="23" rx="1" fill="#C9A84C" opacity=".5"/>
          <rect x="39.5" y="22" width="2.5" height="23" rx="1" fill="#C9A84C" opacity=".5"/>
          <!-- Caja grande izquierda -->
          <rect x="5" y="26" width="11" height="14" rx="1.5" fill="#C9A84C"/>
          <rect x="5" y="26" width="11" height="4" rx="1.5" fill="#b8912e"/>
          <line x1="10.5" y1="30" x2="10.5" y2="40" stroke="#b8912e" stroke-width="0.8"/>
          <!-- Caja pequeña centro -->
          <rect x="18" y="30" width="8" height="10" rx="1.5" fill="#C9A84C" opacity=".85"/>
          <rect x="18" y="30" width="8" height="3" rx="1.5" fill="#b8912e" opacity=".85"/>
          <!-- Caja mediana derecha -->
          <rect x="28" y="27" width="10" height="13" rx="1.5" fill="#C9A84C" opacity=".7"/>
          <rect x="28" y="27" width="10" height="3.5" rx="1.5" fill="#b8912e" opacity=".7"/>
          <line x1="33" y1="30.5" x2="33" y2="40" stroke="#b8912e" stroke-width="0.8" opacity=".7"/>
          <!-- Texto -->
          <text x="52" y="28" font-family="Georgia, serif" font-size="21" font-weight="700" letter-spacing="2.5" fill="{{ section.settings.text_color }}">EL ESTANTE</text>
          <line x1="52" y1="33" x2="212" y2="33" stroke="#C9A84C" stroke-width="1"/>
          <text x="52" y="45" font-family="Georgia, serif" font-size="9.5" letter-spacing="6" fill="#C9A84C">C H I L E</text>
        </svg>
      {%- endif -%}
    </a>

    {%- if section.settings.menu != blank -%}
      <nav class="header__nav" aria-label="Principal">
        <ul>
          {%- for link in linklists[section.settings.menu].links -%}
            <li>
              <a href="{{ link.url }}"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <div class="header__actions">
      <button class="header__icon-btn" aria-label="Buscar" data-search-toggle>
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </button>
      {%- if shop.customer_accounts_enabled -%}
        <a href="/account" class="header__icon-btn" aria-label="Mi cuenta">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
          </svg>
        </a>
      {%- endif -%}
      <a href="/cart" class="header__icon-btn header__cart-wrap" aria-label="Carrito">
        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
      <button class="header__icon-btn header__hamburger" aria-label="Menú" data-menu-open>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<div class="header__drawer" id="mobile-drawer" role="dialog" aria-modal="true">
  <div class="header__drawer-panel">
    <button class="header__drawer-close" data-menu-close aria-label="Cerrar">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    {%- if section.settings.menu != blank -%}
      <ul>
        {%- for link in linklists[section.settings.menu].links -%}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

<script>
(function(){
  var btn = document.querySelector('[data-menu-open]');
  var close = document.querySelector('[data-menu-close]');
  var drawer = document.getElementById('mobile-drawer');
  if(!btn || !drawer) return;
  btn.addEventListener('click', function(){ drawer.classList.add('is-open'); document.body.style.overflow='hidden'; });
  close && close.addEventListener('click', closeDrawer);
  drawer.addEventListener('click', function(e){ if(e.target===drawer) closeDrawer(); });
  function closeDrawer(){ drawer.classList.remove('is-open'); document.body.style.overflow=''; }
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (opcional, reemplaza el SVG)" },
    { "type": "link_list", "id": "menu", "label": "Menú de navegación", "default": "main-menu" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Texto / íconos", "default": "#0d0d0d" }
  ]
}
{% endschema %}
