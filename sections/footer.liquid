{%- style -%}
  .footer {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 5rem 2rem 0;
  }
  .footer__grid {
    max-width: 1400px; margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255,255,255,.1);
  }
  @media (max-width: 900px) { .footer__grid { grid-template-columns: 1fr 1fr; } .footer__brand { grid-column: 1/-1; } }
  @media (max-width: 480px) { .footer__grid { grid-template-columns: 1fr; } }

  .footer__logo-svg { height: 44px; width: auto; margin-bottom: 1.25rem; }
  .footer__desc { font-size: .9rem; opacity: .6; line-height: 1.7; max-width: 300px; margin-bottom: 1.75rem; }
  .footer__social { display: flex; gap: .75rem; }
  .footer__social a {
    width: 40px; height: 40px;
    border: 1px solid rgba(255,255,255,.2); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: {{ section.settings.text_color }};
    transition: border-color .2s, background .2s;
  }
  .footer__social a:hover { border-color: #c9a84c; background: rgba(201,168,76,.1); }

  .footer__col-title {
    font-size: .72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .12em;
    color: #c9a84c; margin-bottom: 1.25rem;
  }
  .footer__links { list-style: none; }
  .footer__links li + li { margin-top: .625rem; }
  .footer__links a { font-size: .88rem; opacity: .65; transition: opacity .2s; }
  .footer__links a:hover { opacity: 1; }

  .footer__bottom {
    max-width: 1400px; margin: 0 auto;
    padding: 1.75rem 0;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
    font-size: .78rem; opacity: .5;
  }
  .footer__payments { display: flex; gap: .4rem; align-items: center; }
  .footer__payments svg { height: 24px; width: auto; }
{%- endstyle -%}

<footer class="footer" role="contentinfo">
  <div class="footer__grid">
    <div class="footer__brand">
      <svg class="footer__logo-svg" viewBox="0 0 220 64" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="1"  y="2" width="2.5" height="58" rx="1.2" fill="#C9A84C"/>
        <rect x="42" y="2" width="2.5" height="58" rx="1.2" fill="#C9A84C"/>
        <rect x="1" y="2"  width="44" height="2.5" rx="1.2" fill="#C9A84C"/>
        <rect x="1" y="32" width="44" height="2.5" rx="1.2" fill="#C9A84C"/>
        <rect x="1" y="60" width="44" height="2.5" rx="1.2" fill="#C9A84C"/>
        <rect x="5"  y="6"  width="10" height="24" rx="1.5" fill="#C9A84C"/>
        <rect x="5"  y="6"  width="10" height="5"  rx="1.5" fill="#a87828"/>
        <rect x="17" y="9"  width="8"  height="21" rx="1.5" fill="#C9A84C" opacity=".8"/>
        <rect x="17" y="9"  width="8"  height="4"  rx="1.5" fill="#a87828" opacity=".8"/>
        <rect x="27" y="7"  width="11" height="23" rx="1.5" fill="#C9A84C" opacity=".65"/>
        <rect x="27" y="7"  width="11" height="5"  rx="1.5" fill="#a87828" opacity=".65"/>
        <rect x="5"  y="36" width="9"  height="22" rx="1.5" fill="#C9A84C" opacity=".7"/>
        <rect x="5"  y="36" width="9"  height="4"  rx="1.5" fill="#a87828" opacity=".7"/>
        <rect x="16" y="38" width="12" height="20" rx="1.5" fill="#C9A84C"/>
        <rect x="16" y="38" width="12" height="5"  rx="1.5" fill="#a87828"/>
        <rect x="30" y="36" width="9"  height="22" rx="1.5" fill="#C9A84C" opacity=".75"/>
        <rect x="30" y="36" width="9"  height="5"  rx="1.5" fill="#a87828" opacity=".75"/>
        <text x="54" y="30" font-family="Georgia, serif" font-size="21" font-weight="700" letter-spacing="2.5" fill="{{ section.settings.text_color }}">EL ESTANTE</text>
        <line x1="54" y1="35" x2="214" y2="35" stroke="#C9A84C" stroke-width="1"/>
        <text x="54" y="47" font-family="Georgia, serif" font-size="9.5" letter-spacing="6" fill="#C9A84C">C H I L E</text>
      </svg>
      {%- if section.settings.brand_desc != blank -%}
        <p class="footer__desc">{{ section.settings.brand_desc }}</p>
      {%- endif -%}
      <div class="footer__social">
        {%- if section.settings.social_instagram != blank -%}
          <a href="{{ section.settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_facebook != blank -%}
          <a href="{{ section.settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.social_tiktok != blank -%}
          <a href="{{ section.settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-6.28 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34l-.01-8.41a8.16 8.16 0 0 0 4.77 1.52V5.01a4.85 4.85 0 0 1-1-.32z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }}>
        <p class="footer__col-title">{{ block.settings.title }}</p>
        {%- if block.settings.menu != blank -%}
          <ul class="footer__links">
            {%- for link in linklists[block.settings.menu].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <div class="footer__bottom">
    <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.</span>
    {%- if section.settings.show_payment_icons -%}
      <div class="footer__payments">
        {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'payment-icon' }}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 40" style="height:24px;width:auto;vertical-align:middle;" aria-label="Mercado Pago">
          <rect width="60" height="40" rx="5" fill="#00B1EA"/>
          <text x="50%" y="56%" dominant-baseline="middle" text-anchor="middle" font-family="Arial,sans-serif" font-size="7" font-weight="bold" fill="#ffffff">MERCADO</text>
          <text x="50%" y="76%" dominant-baseline="middle" text-anchor="middle" font-family="Arial,sans-serif" font-size="7" font-weight="bold" fill="#ffffff">PAGO</text>
        </svg>
      </div>
    {%- endif -%}
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "link_column",
      "name": "Columna de enlaces",
      "settings": [
        { "type": "text", "id": "title", "label": "Título", "default": "Información" },
        { "type": "link_list", "id": "menu", "label": "Menú" }
      ]
    }
  ],
  "settings": [
    { "type": "textarea", "id": "brand_desc", "label": "Descripción de la marca", "default": "Tu tienda de confianza con los mejores productos y envío a todo Chile." },
    { "type": "url", "id": "social_instagram", "label": "Instagram URL" },
    { "type": "url", "id": "social_facebook", "label": "Facebook URL" },
    { "type": "url", "id": "social_tiktok", "label": "TikTok URL" },
    { "type": "checkbox", "id": "show_payment_icons", "label": "Mostrar métodos de pago", "default": true },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#0d0d0d" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#ffffff" }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_column", "settings": { "title": "Ayuda" } },
        { "type": "link_column", "settings": { "title": "Empresa" } }
      ]
    }
  ]
}
{% endschema %}
